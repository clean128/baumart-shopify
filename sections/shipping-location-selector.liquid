{% liquid
  assign shipping_settings_entry = metaobjects.shipping_settings['shipping-settings'] | default: metaobjects.shipping_settings.values.first
  assign default_region_name = 'Región Metropolitana de Santiago'
  assign default_region_slug = 'region-metropolitana-de-santiago'
  assign default_comuna_name = 'Santiago'
  assign default_comuna_slug = 'santiago'
  assign popup_delay_seconds = 3
  assign global_free_shipping_threshold = 'null'

  if shipping_settings_entry != blank
    if shipping_settings_entry.popup_delay_seconds.value != blank
      assign popup_delay_seconds = shipping_settings_entry.popup_delay_seconds.value
    endif
    if shipping_settings_entry.default_region.value != blank
      assign default_region_name = shipping_settings_entry.default_region.value.name.value | default: default_region_name
      assign default_region_slug = shipping_settings_entry.default_region.value.slug.value | default: default_region_slug
    endif
    if shipping_settings_entry.default_comuna.value != blank
      assign default_comuna_name = shipping_settings_entry.default_comuna.value.name.value | default: default_comuna_name
      assign default_comuna_slug = shipping_settings_entry.default_comuna.value.slug.value | default: default_comuna_slug
    endif
    if shipping_settings_entry.global_free_shipping_threshold.value != blank
      assign global_free_shipping_threshold = shipping_settings_entry.global_free_shipping_threshold.value
    endif
  endif

  assign region_entries = metaobjects.shipping_region.values
  assign comuna_entries = metaobjects.shipping_comuna.values
%}

{%- capture regions_json -%}
  [
    {%- assign has_region = false -%}
    {%- for region in region_entries -%}
      {%- if region.active.value != false -%}
        {%- if has_region -%},{%- endif -%}
        {
          "name": {{ region.name.value | json }},
          "slug": {{ region.slug.value | json }},
          "active": true,
          "default_free_shipping_threshold": {{ region.default_free_shipping_threshold.value | default: 'null' }},
          "sort_order": {{ region.sort_order.value | default: forloop.index | json }}
        }
        {%- assign has_region = true -%}
      {%- endif -%}
    {%- endfor -%}
  ]
{%- endcapture -%}

{%- capture comunas_json -%}
  {% paginate comuna_entries by 250 %}
    [
      {%- assign has_comuna = false -%}
      {%- for comuna in comuna_entries -%}
        {%- assign region_reference = comuna.region.value -%}
        {%- if comuna.active.value != false and region_reference != blank and region_reference.active.value != false -%}
          {%- if has_comuna -%},{%- endif -%}
          {
            "name": {{ comuna.name.value | json }},
            "slug": {{ comuna.slug.value | json }},
            "region_slug": {{ region_reference.slug.value | json }},
            "free_shipping_threshold_override": {{ comuna.free_shipping_threshold_override.value | default: 'null' }},
            "active": true
          }
          {%- assign has_comuna = true -%}
        {%- endif -%}
      {%- endfor -%}
    ]
  {% endpaginate %}
{%- endcapture -%}

{%- capture selector_payload -%}
  {
    "enabled": {{ settings.enable_comuna_shipping_logic | json }},
    "design_mode": {{ request.design_mode | json }},
    "popup_delay_seconds": {{ popup_delay_seconds | json }},
    "defaults": {
      "region_name": {{ default_region_name | json }},
      "region_slug": {{ default_region_slug | json }},
      "comuna_name": {{ default_comuna_name | json }},
      "comuna_slug": {{ default_comuna_slug | json }}
    },
    "translations": {
      "default_context": {{ 'shipping_location_selector.default_context' | t: location: '__location__' | json }},
      "selected_context": {{ 'shipping_location_selector.selected_context' | t: location: '__location__' | json }},
      "location_with_region": {{ 'shipping_location_selector.location_with_region' | t: comuna: '__comuna__', region: '__region__' | json }},
      "badge_context_default": {{ 'shipping_location_selector.badge_context_default' | t: location: '__location__' | json }},
      "badge_context_selected": {{ 'shipping_location_selector.badge_context_selected' | t: location: '__location__' | json }}
    },
    "global_free_shipping_threshold": {{ global_free_shipping_threshold }},
    "regions": {{ regions_json | strip }},
    "comunas": {{ comunas_json | strip }}
  }
{%- endcapture -%}

<script type="application/json" id="ShippingLocationSelectorData-{{ section.id }}">
  {{ selector_payload | strip }}
</script>

{% style %}
  .shipping-location-selector-launcher {
    min-width: 144px;
  }

  .shipping-location-selector-launcher--mobile {
    min-width: 0;
    max-width: 132px;
    padding: 0.5rem 0.625rem;
    gap: 0.375rem;
    border-radius: 999px;
  }

  .shipping-location-selector-launcher--mobile .shipping-location-selector-launcher__icon {
    width: 0.875rem;
    min-width: 0.875rem;
    height: 0.875rem;
    min-height: 0.875rem;
  }

  .shipping-location-selector-launcher--mobile .shipping-location-selector-launcher__label {
    font-size: 0.75rem;
  }

  .shipping-location-selector-launcher--mobile .shipping-location-selector-launcher__caret {
    width: 0.5rem;
    min-width: 0.5rem;
    height: 0.5rem;
    min-height: 0.5rem;
  }

  .shipping-location-selector-modal__overlay {
    background: rgba(15, 23, 42, 0.45);
    backdrop-filter: blur(4px);
  }

  .shipping-location-selector-modal__shell {
    padding: 1.25rem;
  }

  .shipping-location-selector-modal__panel {
    background: rgb(var(--background-color));
    box-shadow: 0 28px 80px rgba(15, 23, 42, 0.18);
  }

  .dark .shipping-location-selector-modal__panel {
    background: rgb(var(--background-color));
  }

  .shipping-location-selector-launcher__icon {
    height: {{ 0.16 | times: settings.text_base_size }}px;
    min-height: {{ 0.16 | times: settings.text_base_size }}px;
    width: {{ 0.16 | times: settings.text_base_size }}px;
    min-width: {{ 0.16 | times: settings.text_base_size }}px;
  }

  .shipping-location-selector-launcher__label {
    font-size: {{ settings.text_base_size | times: 0.00875 }}rem;
  }

  .shipping-location-selector-modal__title {
    font-size: {{ settings.heading_base_size | times: 0.01 }}rem;
  }

  .shipping-location-selector-modal__text,
  .shipping-location-selector-modal__field {
    font-size: {{ settings.text_base_size | times: 0.00875 }}rem;
  }

  .shipping-location-selector-modal__select {
    appearance: none;
    -webkit-appearance: none;
    -moz-appearance: none;
  }

  .shipping-location-selector-modal__select-icon {
    width: 0.875rem;
    height: 0.875rem;
    color: rgba(var(--colors-text), 0.7);
  }

  .shipping-location-selector-modal__button {
    width: 100%;
  }

  @media (min-width: 768px) {
    .shipping-location-selector-modal__shell {
      padding: 2rem;
    }

    .shipping-location-selector-modal__title {
      font-size: {{ settings.heading_base_size | times: 0.0125 }}rem;
    }

    .shipping-location-selector-modal__button {
      width: auto;
      min-width: 220px;
    }
  }
{% endstyle %}

<div x-data x-init="$store.xShippingLocationSelector?.init('{{ section.id }}')">
  <div
    x-show="$store.xShippingLocationSelector?.show"
    x-cloak
    class="flex items-end md:items-center fixed top-0 left-0 right-0 bottom-0 z-[60]"
  >
    <div
      class="shipping-location-selector-modal__overlay absolute top-0 left-0 right-0 bottom-0"
      @click="$store.xShippingLocationSelector?.dismiss()"
    ></div>
    <div
      role="dialog"
      aria-modal="true"
      aria-label="{{ 'shipping_location_selector.title' | t }}"
      x-show="$store.xShippingLocationSelector?.show"
      x-transition:enter="transition-all ease-in-out duration-500"
      x-transition:enter-start="opacity-0 transform translate-y-1/3"
      x-transition:enter-end="opacity-100 transform translate-y-0"
      x-transition:leave="transition-all ease-in-out duration-500"
      x-transition:leave-end="opacity-0 transform translate-y-1/3"
      class="quick_view flex items-end md:items-center fixed top-0 left-0 right-0 bottom-0 z-[60]"
      @keydown.escape.window="$store.xShippingLocationSelector?.dismiss()"
    >
      <div
        role="dialog"
        class="shipping-location-selector-modal__shell duration-400 x-pgw md:page-width w-full"
        @click.away="$store.xShippingLocationSelector?.dismiss()"
      >
        <div class="shipping-location-selector-modal__panel relative max-h-[90vh] md:max-h-[80vh] overflow-hidden md:w-[560px] md:mx-auto{% if settings.edges_type == 'rounded_corners' %} rounded-[20px]{% endif %}">
          <div class="flex items-start justify-between gap-6 border-b border-[rgba(var(--colors-line-and-border))] pt-5 pb-5 pl-5 pr-5 md:pt-6 md:pb-6 md:pl-8 md:pr-8">
            <div>
              <div class="shipping-location-selector-modal__title font-medium h2">{{ 'shipping_location_selector.title' | t }}</div>
              <p class="shipping-location-selector-modal__text mt-2 opacity-70">{{ 'shipping_location_selector.description' | t }}</p>
              <p
                x-show="$store.xShippingLocationSelector?.getStatusMessage()"
                x-text="$store.xShippingLocationSelector?.getStatusMessage()"
                class="shipping-location-selector-modal__text mt-2 font-medium"
              ></p>
            </div>
            <button
              type="button"
              aria-label="{{ 'accessibility.close' | t }}"
              class="icon-close-container rounded-full group-close-btn flex items-center justify-center"
              @click="$store.xShippingLocationSelector?.dismiss()"
            >
              {% render 'icon-alls', icon: 'icon-close', animation_class: 'icon-close-animation' %}
            </button>
          </div>
          <div class="pt-5 pb-5 pl-5 pr-5 md:pt-6 md:pb-6 md:pl-8 md:pr-8">
            <template x-if="$store.xShippingLocationSelector?.canRender()">
              <div class="flex flex-col gap-5">
                <div class="flex flex-col gap-2">
                  <label class="shipping-location-selector-modal__field font-medium" for="shipping-location-region-{{ section.id }}">{{ 'shipping_location_selector.region_label' | t }}</label>
                  <div class="relative">
                    <select
                      id="shipping-location-region-{{ section.id }}"
                      class="shipping-location-selector-modal__select w-full border border-[rgba(var(--colors-line-and-border))] bg-transparent pt-3 pb-3 pl-4 pr-10{% if settings.edges_type == 'rounded_corners' %} rounded-[10px]{% endif %}"
                      x-model="$store.xShippingLocationSelector.form.regionSlug"
                      @change="$store.xShippingLocationSelector?.onRegionChange($event.target.value)"
                    >
                      <option value="">{{ 'shipping_location_selector.region_placeholder' | t }}</option>
                      <template x-for="region in $store.xShippingLocation?.regions" :key="region.slug">
                        <option :value="region.slug" x-text="region.name"></option>
                      </template>
                    </select>
                    <span class="shipping-location-selector-modal__select-icon pointer-events-none absolute top-1/2 right-4 -translate-y-1/2 rtl:right-auto rtl:left-4">
                      <svg viewBox="0 0 10 6" fill="none" xmlns="http://www.w3.org/2000/svg" class="block w-full h-full">
                        <path d="M1 1L5 5L9 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                    </span>
                  </div>
                </div>
                <div class="flex flex-col gap-2">
                  <label class="shipping-location-selector-modal__field font-medium" for="shipping-location-comuna-{{ section.id }}">{{ 'shipping_location_selector.comuna_label' | t }}</label>
                  <div class="relative">
                    <select
                      id="shipping-location-comuna-{{ section.id }}"
                      class="shipping-location-selector-modal__select w-full border border-[rgba(var(--colors-line-and-border))] bg-transparent pt-3 pb-3 pl-4 pr-10{% if settings.edges_type == 'rounded_corners' %} rounded-[10px]{% endif %}"
                      :disabled="!$store.xShippingLocationSelector?.form.regionSlug"
                      x-model="$store.xShippingLocationSelector.form.comunaSlug"
                    >
                      <option value="">{{ 'shipping_location_selector.comuna_placeholder' | t }}</option>
                      <template x-for="comuna in $store.xShippingLocationSelector?.getAvailableComunas()" :key="comuna.slug">
                        <option :value="comuna.slug" x-text="comuna.name"></option>
                      </template>
                    </select>
                    <span class="shipping-location-selector-modal__select-icon pointer-events-none absolute top-1/2 right-4 -translate-y-1/2 rtl:right-auto rtl:left-4">
                      <svg viewBox="0 0 10 6" fill="none" xmlns="http://www.w3.org/2000/svg" class="block w-full h-full">
                        <path d="M1 1L5 5L9 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                    </span>
                  </div>
                </div>
                <p class="shipping-location-selector-modal__text opacity-70">{{ 'shipping_location_selector.helper_text' | t }}</p>
                <button
                  type="button"
                  class="shipping-location-selector-modal__button button button-solid inline-flex justify-center items-center min-w-[90px] whitespace-nowrap pl-9 pr-9 pt-3 pb-3 leading-normal"
                  :class="$store.xShippingLocationSelector?.canSave() ? 'pointer-events-auto' : 'pointer-events-none opacity-60'"
                  @click="$store.xShippingLocationSelector?.save()"
                >
                  <span class="button-text">{{ 'shipping_location_selector.save' | t }}</span>
                </button>
              </div>
            </template>
            <template x-if="!$store.xShippingLocationSelector?.canRender()">
              <p class="shipping-location-selector-modal__text opacity-70">{{ 'shipping_location_selector.empty' | t }}</p>
            </template>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div x-data="{ headerContainer: !!document.querySelector('#x-header-container .x-header-store-selector-container') }">
    <template x-if="headerContainer && $store.xShippingLocationSelector?.canRender()">
      <template x-teleport="#x-header-container .x-header-store-selector-container">
        <button
          type="button"
          class="shipping-location-selector-launcher text-[rgba(var(--colors-text-secondary))] bg-[rgba(var(--colors-background-secondary))] cursor-pointer rounded-full h-fit pt-2 pb-2 pl-2 pr-2 flex flex-row gap-2.5 items-center w-max max-w-[240px]"
          @click="$store.xShippingLocationSelector?.open()"
        >
          <span class="shipping-location-selector-launcher__icon block">
            {% render 'icon-alls', icon: 'icon-store-selector', animation_class: 'icon-animation' %}
          </span>
          <span class="shipping-location-selector-launcher__label text-left rtl:text-right leading-tight min-w-0 flex flex-col">
            <span class="flex items-center gap-1.5 min-w-0">
              <span x-text="$store.xShippingLocationSelector?.getLauncherPrimaryText()" class="font-medium truncate"></span>
              <span
                x-show="$store.xShippingLocationSelector?.usesDefaultFallback()"
                class="text-[0.7em] uppercase tracking-wide opacity-70"
              >
                {{ 'shipping_location_selector.default_badge' | t }}
              </span>
            </span>
            <span x-text="$store.xShippingLocationSelector?.getLauncherSecondaryText()" class="line-clamp-1 opacity-70"></span>
          </span>
          <span class="block w-2 h-2 min-w-[8px] min-h-[8px] self-center">{% render 'icon-alls', icon: 'icon-caret' %}</span>
        </button>
      </template>
    </template>
  </div>

  <template x-if="!runDispatch">
    <div x-data="{ mobileHeader: !!document.querySelector('#x-header-container .x-header-store-selector-mobile-container') }">
      <template x-if="mobileHeader && $store.xShippingLocationSelector?.canRender()">
        <template x-teleport="#x-header-container .x-header-store-selector-mobile-container">
          <button
            type="button"
            class="shipping-location-selector-launcher shipping-location-selector-launcher--mobile text-[rgb(var(--colors-text-header))] bg-[rgba(var(--colors-line-header),1)] cursor-pointer h-fit flex flex-row items-center"
            @click="$store.xShippingLocationSelector?.open()"
            aria-label="{{ 'shipping_location_selector.title' | t }}"
          >
            <span class="shipping-location-selector-launcher__icon block shrink-0">
              {% render 'icon-alls', icon: 'icon-store-selector', animation_class: 'icon-animation' %}
            </span>
            <span class="shipping-location-selector-launcher__label text-left rtl:text-right leading-tight min-w-0 flex-1">
              <span x-text="$store.xShippingLocationSelector?.getLauncherPrimaryText()" class="font-medium truncate block"></span>
            </span>
            <span class="shipping-location-selector-launcher__caret block shrink-0">{% render 'icon-alls', icon: 'icon-caret' %}</span>
          </button>
        </template>
      </template>
    </div>
  </template>
</div>

<script src="{{ 'shipping-location-catalog.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'shipping-location-selector.js' | asset_url }}" defer="defer"></script>

{% schema %}
{
  "name": "Shipping location modal",
  "class": "section section-shipping-location-selector x-section",
  "enabled_on": {
    "groups": ["aside"]
  },
  "limit": 1,
  "tag": "section",
  "settings": [
    {
      "type": "paragraph",
      "content": "Uses the comuna shipping metaobjects created by the import helper. Keep the global comuna shipping toggle disabled until the full rollout is complete."
    }
  ],
  "presets": [
    {
      "name": "Shipping location modal"
    }
  ]
}
{% endschema %}
